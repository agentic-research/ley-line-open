# Default deny — only explicitly allowed files are tracked.
# Deny all files by default.
*

# Allow traversing directories (required for nested allow rules).
!*/

# Root files
!.gitignore
!LICENSE
!README.md
!CHANGELOG.md

# GitHub Actions
!.github/**

# Rust workspace
!rs/Cargo.toml
!rs/Cargo.lock

# ll-core crates (Tier 1: OSS infrastructure)
!rs/ll-core/**

# ll-open crates (Tier 2: OSS projection engine)
!rs/ll-open/**

# Build infrastructure
!Taskfile.yml
!rs/pkgconfig/**
!entitlements.plist

# Image build — configs tracked, artifacts/keys local-only.
# Active path: `task image` uses krust + image.Dockerfile (see Taskfile.yml).
# apko.yaml / melange.yaml retained for reference but the path was abandoned
# on Apple Silicon (see ley-line-open-2b255c).
!apko.yaml
!melange.yaml
!image.Dockerfile

# Documentation
!docs/**

# Go bindings module — clients/go/leyline-schema/ ships generated *.capnp.go
# files; the regen-diff CI gate (.github/workflows/leyline-schema-go.yml)
# requires them to be tracked, not gitignored.
!clients/**

# Re-deny build artifacts
**/target/
**/*.a
**/*.o
**/*.so
**/*.dylib
**/*.d

# CRUMB - personal memory (not tracked)
.crumb/
