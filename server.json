{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.agentic-research/ley-line-open",
  "description": "Open-source data plane primitives — tree-sitter parse, LSP, sheaf cache, observation lattice.",
  "version": "0.5.4",
  "repository": {
    "url": "https://github.com/agentic-research/ley-line-open.git",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "oci",
      "identifier": "ghcr.io/agentic-research/ley-line-open:0.5.4",
      "transport": {
        "type": "streamable-http",
        "url": "http://localhost:8384/mcp"
      },
      "environmentVariables": []
    }
  ],
  "_meta": {
    "art.cloister/v1": {
      "groups": [
        {
          "name": "lsp",
          "advertisedPrefix": "lsp_",
          "upstreamNames": [
            "lsp_hover",
            "lsp_defs",
            "lsp_refs",
            "lsp_symbols",
            "lsp_diagnostics"
          ]
        },
        {
          "name": "lifecycle",
          "advertisedPrefix": "",
          "upstreamNames": [
            "status",
            "snapshot",
            "reparse",
            "enrich"
          ]
        },
        {
          "name": "sheaf",
          "advertisedPrefix": "sheaf_",
          "upstreamNames": [
            "sheaf_set_topology",
            "sheaf_invalidate",
            "sheaf_defect",
            "sheaf_stalks",
            "sheaf_status",
            "sheaf_learned_weights"
          ]
        },
        {
          "name": "query",
          "advertisedPrefix": "",
          "upstreamNames": [
            "query",
            "list_children",
            "read_content",
            "find_callers",
            "find_defs",
            "find_callees",
            "get_refs_map",
            "get_defs_map",
            "get_schema",
            "get_db_path",
            "get_node",
            "inspect_symbol",
            "at_position",
            "inspect_neighborhood",
            "search_symbols",
            "agreement"
          ]
        },
        {
          "name": "wire",
          "advertisedPrefix": "",
          "upstreamNames": [
            "leyline_version"
          ]
        },
        {
          "name": "validate",
          "advertisedPrefix": "",
          "upstreamNames": [
            "validate"
          ]
        },
        {
          "name": "hdc",
          "advertisedPrefix": "hdc_",
          "upstreamNames": [
            "hdc_search",
            "hdc_calibrate",
            "hdc_density"
          ]
        }
      ]
    }
  }
}
